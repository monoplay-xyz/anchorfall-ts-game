      "title": "Stars Stand Still",
      "lines": [
        "The fourth dawn finds the shelf intact and the rifts gone quiet, their starlight cold and unmoving.",
        "Whatever drifts through walls drifted back into the dark. For now."
      ],
      "art": "dawn"
    }
