  "intro": [
    {
      "title": "Cinder Gate",
      "lines": [
        "The basin breathes heat. Lava threads the ash in glowing veins and the wind carries cinder like snow.",
        "Wall the south gate and hold it. Everything comes down the plazas from the north — there is no other way in.",
        "Their dead burn where they drop — by the third night the ground in front of your wall is a carpet of fire. Boomer waits past the embers; hold the gate and he is yours."
      ],
      "art": "siege"
    }
  ],
  "outro": [
    {
      "title": "Dawn over the ash",
      "lines": [
        "The last ember dies and the gate still stands. The molten tide has spent itself against your wall.",
        "Boomer steps out of the smoke, nodding once. The basin is yours."
      ],
      "art": "dawn"
    }
  ],
