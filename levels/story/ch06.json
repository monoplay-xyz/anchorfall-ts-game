  "intro": [
    {
      "title": "Chapter VI — Final Settlement",
      "lines": [
        "Three rings of berms cross the open desert between the expedition and the great Settlement Anchor.",
        "The Entropy garrisons every windbreak it ever broke.",
        "One last march across the sand. Keep the signal alive."
      ],
      "art": "settlement"
    }
  ],
  "outro": [
    {
      "title": "The Anchor Settles",
      "lines": [
        "Light walks outward from the gate, ring by ring across the dunes.",
        "Finality spreads over the frontier like a slow, dry dawn.",
        "The land remembers itself."
      ],
      "art": "dawn"
    },
    {
      "title": "Home",
      "lines": [
        "Wrenna's quorum sings. Tarn's odds finally come good.",
        "The Settlement Anchor holds. The frontier is anchored for good — the expedition is home."
      ],
      "art": "anchorcraft"
    }
  ],
