  "outro": [
    {
      "title": "Dawn Over the Mire",
      "lines": [
        "The last wave sinks back into the fog and does not surface again.",
        "Three relays burn steady over the black water. The warden finally sits down.",
        "One road left: east, on dry causeways, to the Settlement."
      ],
      "art": "dawn"
    }
  ],
  "captiveChars": [
    "bastion"
