    {
      "title": "The Corner Holds",
      "lines": [
        "Fifth dawn burns the fog off the flagstones. The two open lanes are choked with the dead.",
        "Whatever the precinct was guarding, it's still standing. So are you."
      ],
      "art": "dawn"
    }
