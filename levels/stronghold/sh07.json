  "ambience": "city",
  "intro": [
    {
      "title": "The Forked Hold",
      "lines": [
        "The tide went out and left a forked saltworks — four beacon monoliths ringing a brine plaza, joined by old stone causeways.",
        "The pools wall off every flank but the causeways, so the waves must funnel through the lane mouths. Hold them, but keep a beacon lit on every bank.",
        "Brine-hulks crawl out of the pools and sap any wall you lean on. Rove the ring, repair the breaches, and don't let the lights go dark."
      ],
      "art": "siege"
    }
  ],
  "outro": [
    {
      "title": "The Forks Still Burn",
      "lines": [
        "Four nights of fog, and light still stands on the forks that mattered.",
        "The tide turns back in over the causeways, quiet now. The sappers have gone back under."
      ],
      "art": "dawn"
    }
  ],
